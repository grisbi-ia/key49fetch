# Key49-Fetch — Environment Configuration
# Copy to .env and fill in your values

# ─── SRI Access ──────────────────────────────────────────────────────
# CapSolver API key for reCAPTCHA bypass (optional — native trust scoring works too)
# CAPSOLVER_API_KEY=CAP-XXXXXXXX

# ─── Security ────────────────────────────────────────────────────────
# Fernet key for encrypting SRI passwords at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=your-generated-fernet-key

# ─── API Gateway ─────────────────────────────────────────────────────
# API key(s) for authenticating REST API consumers (comma-separated)
# If not set, API runs in dev mode (no auth required)
# API_KEYS=key1,key2

# API server configuration
# KEY49_API_HOST=0.0.0.0
# KEY49_API_PORT=8081
# KEY49_API_RELOAD=false

# ─── Paths ───────────────────────────────────────────────────────────
# Base output directory for downloaded files
# KEY49_OUTPUT_DIR=xml_downloads

# Companies configuration file
# KEY49_COMPANIES_CONFIG=config/companies.json

# ─── Instance Partitioning ───────────────────────────────────────────
# Filter which companies this instance handles (comma-separated company IDs)
# Leave empty to process all active companies
# COMPANY_FILTER=0195160252001,0992156406001

# ─── Webhooks ────────────────────────────────────────────────────────
# Webhook config is per-company in config/companies.json:
#   "webhook_url": "https://erp.example.com/api/webhooks/key49",
#   "webhook_secret": "your-hmac-secret"
#
# Audit log is stored in: logs/webhooks/{company_id}.jsonl

# ─── Alerting ────────────────────────────────────────────────────────
# Alert webhook for repeated download failures
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_WEBHOOK_SECRET=optional-hmac-secret
# ALERT_THRESHOLD=3  # consecutive failures before alerting

# ─── SRI Password Override ───────────────────────────────────────────
# Override a specific company's SRI password (useful for testing)
# SRI_PASSWORD_0195160252001=override-password
